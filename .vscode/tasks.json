{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Circle Fight Game",
            "command": "D:/Libraries and Tools/winlibs/mingw64MSVCRT/bin/g++.exe",
            "args": [
                "-g",
                "${workspaceFolder}/src/*.cpp",
                "${workspaceFolder}/vendor/tmxlite/src/*.cpp",
                "${workspaceFolder}/vendor/tmxlite/src/*.c",
                "${workspaceFolder}/vendor/tmxlite/src/detail/*.cpp",
                "-I", "D:/Libraries and Tools/SFML/include",
                "-I", "${workspaceFolder}/vendor/tmxlite/include",
                "-DTMXLITE_STATIC",
                "-L", "D:/Libraries and Tools/SFML/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-o",
                "${workspaceFolder}/bin/circle_fight.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task biên dịch game."
        }
    ]
}